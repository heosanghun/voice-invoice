# Google Gemini API (필수)
GEMINI_API_KEY=your_gemini_api_key_here

# 인증 (JWT 시크릿, 운영 시 변경)
AUTH_SECRET=your_random_secret_here

# Popbill (실제 국세청 발행 - doc/국세청연동_구현가이드.md 참고)
# POPBILL_LINKID=발급받은링크아이디
# POPBILL_SECRET_KEY=발급받은비밀키
# POPBILL_CORP_NUM=1234567890
# POPBILL_IS_TEST=true
# POPBILL_CORP_NAME=공급자상호
# POPBILL_CEO_NAME=대표자명
# POPBILL_ADDR=공급자주소
# POPBILL_CONTACT=담당자명
# POPBILL_TEL=02-000-0000
# POPBILL_EMAIL=admin@example.com
